{
  "name": "merak-protocol-design-system",
  "version": "0.1.2",
  "description": "Merak Protocol design system CSS, component examples, and Codex agent skill.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snowmerak/merakcss.git"
  },
  "homepage": "https://css.saturday.ne.kr",
  "keywords": [
    "design-system",
    "css",
    "dark-ui",
    "codex-skill",
    "agent-workflow",
    "traceability",
    "permission-ui"
  ],
  "style": "src/style.css",
  "exports": {
    ".": "./src/style.css",
    "./style.css": "./src/style.css",
    "./styles/*": "./src/styles/*",
    "./elements/merak-tabs": "./src/elements/merak-tabs.js",
    "./elements/data-components": "./src/elements/merak-data-components.js",
    "./elements/interactive-components": "./src/elements/merak-interactive-elements.js",
    "./skill": "./skills/merak-protocol-design-system/SKILL.md",
    "./skill.md": "./skills/merak-protocol-design-system/SKILL.md"
  },
  "files": [
    "src/*.js",
    "src/elements",
    "src/style.css",
    "src/styles",
    "skills/merak-protocol-design-system",
    "docs/concept.md",
    "docs/custom-elements.md",
    "public/favicon.svg",
    "public/icons.svg",
    "index.html"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test": "playwright test",
    "test:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.1.1"
  }
}
